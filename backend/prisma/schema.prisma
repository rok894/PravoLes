generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum CartStatus {
  OPEN
  CHECKED_OUT
  ABANDONED
}

enum OrderStatus {
  PENDING
  PAID
  CANCELED
}

enum PaymentStatus {
  REQUIRES_ACTION
  SUCCEEDED
  FAILED
}

enum Role {
  USER
  ADMIN
}

enum CustomOrderStatus {
  SUBMITTED
  QUOTED
  ACCEPTED
  PAID
  REJECTED
  CANCELED
}

model Product {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  title       String   @unique
  description String
  image       String
  alt         String
  priceCents  Int
  discountPercent Int @default(0)
  salePriceCents Int?
  currency    String   @default("EUR")
  active      Boolean  @default(true)

  cartItems   CartItem[]
  orderItems  OrderItem[]
  variants    ProductVariant[]

  @@index([active])
}

model ProductVariant {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  color      String?
  size       String?
  wood       String?

  priceCents Int
  stock      Int      @default(0)
  active     Boolean  @default(true)

  cartItems  CartItem[]
  orderItems OrderItem[]

  @@unique([productId, color, size, wood])
  @@index([productId])
}

model Cart {
  id        String     @id @default(cuid())
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  status    CartStatus @default(OPEN)

  email     String?

  sessionId          String?
  source             String?
  checkoutStartedAt  DateTime?

  items     CartItem[]

  order     Order?

  @@index([sessionId])
  @@index([source])
}

model CartItem {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cartId    String
  productId String
  variantId String?
  qty       Int      @default(1)

  cart      Cart            @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product         @relation(fields: [productId], references: [id], onDelete: Restrict)
  variant   ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@unique([cartId, productId, variantId])
  @@index([cartId])
  @@index([variantId])
}

model Order {
  id               String      @id @default(cuid())
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  status           OrderStatus @default(PENDING)

  cartId           String      @unique
  cart             Cart        @relation(fields: [cartId], references: [id], onDelete: Restrict)

  totalCents       Int
  currency         String      @default("EUR")

  customerEmail    String?

  items            OrderItem[]
  payment          Payment?
}

model OrderItem {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orderId     String
  productId   String?
  variantId   String?

  title       String
  description String
  image       String
  alt         String
  priceCents  Int
  qty         Int

  variantColor String?
  variantSize  String?
  variantWood  String?

  order       Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product     Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)
  variant     ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([variantId])
}

model Payment {
  id                 String        @id @default(cuid())
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  status             PaymentStatus @default(REQUIRES_ACTION)

  orderId            String?       @unique
  order              Order?        @relation(fields: [orderId], references: [id], onDelete: Cascade)

  customOrderId      String?       @unique
  customOrder        CustomOrderRequest? @relation(fields: [customOrderId], references: [id], onDelete: Cascade)

  stripeCustomerId   String?
  stripeSessionId    String?       @unique
  stripePaymentIntentId String?    @unique
}

model CustomOrderRequest {
  id              String             @id @default(cuid())
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  userId          String?
  user            User?              @relation(fields: [userId], references: [id], onDelete: SetNull)

  email           String
  name            String
  phone           String?
  description     String
  dimensions      String?

  status          CustomOrderStatus  @default(SUBMITTED)

  quotePriceCents Int?
  currency        String             @default("EUR")
  quoteMessage    String?
  adminNotes      String?

  quotedAt        DateTime?
  acceptedAt      DateTime?
  paidAt          DateTime?
  rejectedAt      DateTime?
  canceledAt      DateTime?

  images          CustomOrderImage[]
  payment         Payment?

  @@index([status])
  @@index([userId])
  @@index([email])
}

model CustomOrderImage {
  id        String             @id @default(cuid())
  createdAt DateTime           @default(now())

  requestId String
  request   CustomOrderRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  path      String
  mimeType  String
  sizeBytes Int

  @@index([requestId])
}

model ContactMessage {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  name      String
  email     String
  message   String
  read      Boolean  @default(false)
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  expiresAt DateTime
  tokenHash String   @unique
  email     String
  used      Boolean  @default(false)

  @@index([email])
  @@index([expiresAt])
}

model User {
  id                    String    @id @default(cuid())
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  email                 String    @unique
  passwordHash          String
  role                  Role      @default(USER)

  failedLoginAttempts   Int       @default(0)
  lockedUntil           DateTime?

  sessions              Session[]
  customOrders          CustomOrderRequest[]

  @@index([lockedUntil])
}

model Session {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  expiresAt DateTime

  tokenHash String   @unique

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model WebhookEvent {
  id          String   @id
  type        String
  processedAt DateTime @default(now())

  @@index([processedAt])
}

model Visit {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  source    String
  referrer  String?
  path      String?

  sessionId String?
  device    String?
  country   String?

  @@index([createdAt])
  @@index([source])
  @@index([sessionId])
}
